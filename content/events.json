{
  "schemaVersion": 1,
  "kind": "EventCollection",
  "id": "events",
  "events": [
    {
      "id": "evt_cleanse_at_sunken_ruin",
      "trigger": { "type": "regionNodeEntry", "nodeId": "sunken_ruin" },
      "actions": [
        { "type": "showMessage", "text": { "en": "You perform the rite at the Sunken Ruin. Ashvale is cleansed." } },
        { "type": "setStoryFlag", "flag": "ashvale_cleansed" }
      ],
      "repeat": { "mode": "once" }
    },
    {
      "id": "evt_trap_at_clocktower",
      "trigger": { "type": "regionNodeEntry", "nodeId": "clocktower_square" },
      "actions": [
        { "type": "showMessage", "text": { "en": "The clocktower's curse takes hold. Ashvale is lost." } },
        { "type": "setStoryFlag", "flag": "ashvale_lost" }
      ],
      "repeat": { "mode": "once" }
    },
    {
      "id": "evt_supply_cart_pickup",
      "trigger": { "type": "regionNodeEntry", "nodeId": "supply_cart" },
      "actions": [
        { "type": "showMessage", "text": { "en": "The supply cart yields a traveler's ration and a worn iron sword." } },
        { "type": "giveItem",     "itemId": "item_traveler_ration", "amount": 1 },
        { "type": "giveArtifact", "artifactId": "artifact_iron_sword", "amount": 1 }
      ],
      "repeat": { "mode": "once" }
    },
    {
      "id": "evt_secure_vale_market",
      "trigger": { "type": "regionNodeEntry", "nodeId": "vale_market" },
      "actions": [
        { "type": "showMessage", "text": { "en": "You rally the Riverside Vale market. The vale is secured." } },
        { "type": "setStoryFlag", "flag": "vale_secured" }
      ],
      "repeat": { "mode": "once" }
    },
    {
      "id": "evt_guard_steel_mine",
      "trigger": { "type": "regionNodeEntry", "nodeId": "town_center" },
      "actions": [
        { "type": "showMessage", "text": { "en": "Raiders have seized the Steel Mine to the north." } },
        { "type": "spawnTeam", "teamColor": "Red", "nodeId": "iron_mine" }
      ],
      "repeat": { "mode": "once" }
    }
  ]
}
